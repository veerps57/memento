{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"]
  },
  "include": ["src/**/*", "src/**/*.tsx"],
  "exclude": ["dist", "dist-ui", "node_modules"],
  "references": [{ "path": "../schema" }, { "path": "../core" }]
}
