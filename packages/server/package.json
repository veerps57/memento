{
  "name": "@psraghuveer/memento-server",
  "version": "0.3.6",
  "description": "MCP server adapter for Memento. Translates MCP tool calls into command-registry invocations.",
  "keywords": ["memento", "memory", "ai", "assistant", "mcp", "local-first", "sqlite"],
  "license": "Apache-2.0",
  "author": "veerps57",
  "homepage": "https://runmemento.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veerps57/memento.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/veerps57/memento/issues"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod-to-json-schema": "3.25.2",
    "@psraghuveer/memento-core": "workspace:^",
    "@psraghuveer/memento-schema": "workspace:^"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8",
    "zod": "3.25.76"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "test": "vitest run"
  }
}
