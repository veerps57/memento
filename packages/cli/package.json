{
  "name": "@psraghuveer/memento",
  "version": "0.8.0",
  "mcpName": "com.runmemento/memento",
  "description": "Local-first, LLM-agnostic memory layer for AI assistants. Run via npx @psraghuveer/memento.",
  "keywords": [
    "memento",
    "memory",
    "ai",
    "ai-memory",
    "assistant",
    "ai-assistant",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "llm",
    "llm-memory",
    "local-first",
    "sqlite",
    "claude",
    "claude-code",
    "cursor",
    "copilot",
    "cline",
    "opencode",
    "aider"
  ],
  "license": "Apache-2.0",
  "author": "veerps57",
  "homepage": "https://runmemento.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veerps57/memento.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/veerps57/memento/issues"
  },
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "memento": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "scripts", "skills", "packs", "README.md"],
  "dependencies": {
    "@clack/prompts": "0.8.2",
    "@hono/node-server": "1.13.7",
    "open": "10.1.0",
    "@psraghuveer/memento-core": "workspace:^",
    "@psraghuveer/memento-dashboard": "workspace:^",
    "@psraghuveer/memento-embedder-local": "workspace:^",
    "@psraghuveer/memento-schema": "workspace:^",
    "@psraghuveer/memento-server": "workspace:^"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8",
    "zod": "3.25.76"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:skills": "node ./scripts/copy-skills.mjs",
    "build:packs": "node ./scripts/copy-packs.mjs",
    "build": "node ./scripts/copy-skills.mjs && node ./scripts/copy-packs.mjs && tsup",
    "clean": "rm -rf dist skills packs .turbo *.tsbuildinfo",
    "test": "vitest run",
    "postinstall": "node ./scripts/postinstall.mjs",
    "prepack": "node ./scripts/copy-skills.mjs && node ./scripts/copy-packs.mjs"
  }
}
