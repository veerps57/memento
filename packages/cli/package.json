{
  "name": "@psraghuveer/memento",
  "version": "0.2.0",
  "description": "Local-first, LLM-agnostic memory layer for AI coding assistants. Run via npx @psraghuveer/memento.",
  "keywords": ["memento", "memory", "ai", "assistant", "mcp", "local-first", "sqlite"],
  "license": "Apache-2.0",
  "author": "veerps57",
  "homepage": "https://github.com/veerps57/memento#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veerps57/memento.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/veerps57/memento/issues"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "memento": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "scripts", "README.md"],
  "dependencies": {
    "@psraghuveer/memento-core": "workspace:^",
    "@psraghuveer/memento-embedder-local": "workspace:^",
    "@psraghuveer/memento-schema": "workspace:^",
    "@psraghuveer/memento-server": "workspace:^"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8",
    "zod": "3.25.76"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "test": "vitest run",
    "postinstall": "node ./scripts/postinstall.mjs"
  }
}
