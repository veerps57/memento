{
  "name": "@psraghuveer/memento-embedder-local",
  "version": "0.2.1",
  "description": "Local-only embedding provider for Memento, backed by transformers.js (bge-small-en-v1.5). Lazy-loaded.",
  "keywords": ["memento", "memory", "ai", "assistant", "mcp", "local-first", "sqlite"],
  "license": "Apache-2.0",
  "author": "veerps57",
  "homepage": "https://github.com/veerps57/memento#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veerps57/memento.git",
    "directory": "packages/embedder-local"
  },
  "bugs": {
    "url": "https://github.com/veerps57/memento/issues"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@psraghuveer/memento-core": "workspace:^",
    "@psraghuveer/memento-schema": "workspace:^"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "5.7.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  }
}
