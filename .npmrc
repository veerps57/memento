# pnpm settings for the Memento workspace.
#
# - strict-peer-dependencies: surface peer-dep mismatches early.
# - auto-install-peers: but still install them automatically once surfaced.
# - dedupe-peer-dependents: keep a single resolved version across the workspace.
# - resolution-mode=highest: deterministic, prefer newest matching version.
# - save-workspace-protocol=rolling: cross-package deps use workspace:^ so that
#   published versions stay in sync with the monorepo on release.

strict-peer-dependencies=true
auto-install-peers=true
dedupe-peer-dependents=true
resolution-mode=highest
save-workspace-protocol=rolling
engine-strict=true
